# --- Backend FastAPI (login JWT, registros OCR por HTTP) ---
# URL sin barra final. El cliente debe poder alcanzarla al arrancar la app.
API_BASE_URL=http://127.0.0.1:8000
# Rutas relativas (deben empezar por /)
LOGIN_ENDPOINT=/auth/login
REGISTROS_ENDPOINT=/registros
API_TIMEOUT_SECONDS=60

# Clave API de OpenAI (obligatorio para enviar a IA)
OPENAI_API_KEY=sk-...

# Modelo (por defecto gpt-4o, no cambiar desde la UI)
OPENAI_MODEL=gpt-4o

# Timeout en segundos para llamadas a la API
TIMEOUT_SECONDS=60

# Carpeta destino para exportaciones CSV/Excel
# Por defecto: app/data/exports
EXPORT_DIR=app/data/exports

# Solo tests / depuración local del repositorio: 1 = SQLite local en cliente (no usar en producción)
# OCR_USE_SQLITE_REPOSITORY=

# --- Base de datos ---
# sqlite (por defecto, desarrollo local) | mysql (producción / CyberPanel)
DB_ENGINE=sqlite

# MySQL / InnoDB (solo si DB_ENGINE=mysql). Base existente en el servidor (ej. tools_OCR).
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=tools_OCR
